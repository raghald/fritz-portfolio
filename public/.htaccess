# Static export (Next.js output: "export", trailingSlash: true) na Apache.
# Plik kopiowany jest do out/ przy buildzie.
#
# Strategia URL: EN kanoniczna bez prefiksu (/, /about/, /works/...),
# PL pod /pl/ (/pl/, /pl/about/, ...).

RewriteEngine On

# 1. Stare URL-e /en/* -> /* (301, transferuje link equity z poprzedniej wersji).
RewriteRule ^en/?$ / [R=301,L]
RewriteRule ^en/(.*)$ /$1 [R=301,L]

# 2. Trailing slash dla katalogów (zgodne z trailingSlash: true).
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !(/$)
RewriteRule ^(.*)$ /$1/ [R=301,L]

DirectoryIndex index.html

# 3. Niestandardowa strona 404 — fallback do PL gdy ścieżka jest pod /pl/,
#    w pozostałych przypadkach do EN.
ErrorDocument 404 /404.html

# Cache — statyki długi, HTML krótki (pozwala na rotację po deployu).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
</IfModule>

# Cache-Control: immutable dla niezmiennych assetów — repeat visits pomijają revalidation.
<IfModule mod_headers.c>
  <FilesMatch "\.(mp4|webm|webp|avif|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Kompresja (jeśli SeoHost ma mod_deflate).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
