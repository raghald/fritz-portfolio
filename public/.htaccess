# Static export (Next.js output: "export", trailingSlash: true) na Apache.
# Plik kopiowany jest do out/ przy buildzie.

RewriteEngine On

# 1. Root "/" -> /en/ (domyślny locale; brak middleware w static export).
RewriteRule ^$ /en/ [R=302,L]

# 2. Bez locale w ścieżce (np. /about/, /works/) -> /en/<reszta>.
RewriteCond %{REQUEST_URI} !^/(en|pl)(/|$)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/?$ /en/$1/ [R=302,L]

# 3. Trailing slash dla katalogów (zgodne z trailingSlash: true).
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !(/$)
RewriteRule ^(.*)$ /$1/ [R=301,L]

DirectoryIndex index.html

# Niestandardowa strona 404 wyrenderowana z [locale]/not-found.tsx.
ErrorDocument 404 /en/404.html

# Cache — statyki długi, HTML krótki (pozwala na rotację po deployu).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
</IfModule>

# Kompresja (jeśli SeoHost ma mod_deflate).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
